{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd app && npm install && npx next build",
    "watchPatterns": ["app/**"]
  },
  "deploy": {
    "startCommand": "cd app && node .next/standalone/server.js",
    "healthcheckPath": "/api/rates",
    "restartPolicyType": "ON_FAILURE"
  }
}
